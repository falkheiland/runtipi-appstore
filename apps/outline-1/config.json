{
  "$schema": "../schema.json",
  "name": "Outline (OIDC)",
  "port": 8223,
  "available": true,
  "exposable": true,
  "force_expose": true,
  "id": "outline-1",
  "tipi_version": 1,
  "version": "0.75.2",
  "categories": [
    "utilities"
  ],
  "description": "Outline is a knowledge base designed for teams. It's goals are to be fast, intuitive and support many integrations.",
  "short_desc": "A home for all your docs",
  "author": "outline",
  "source": "https://github.com/outline/outline",
  "website": "https://getoutline.com",
  "form_fields": [
    {
      "type": "random",
      "label": "Database Password",
      "env_variable": "POSTGRES_PASSWORD"
    },
    {
      "type": "random",
      "label": "Secret Key",
      "min": 64,
      "max": 64,
      "env_variable": "SECRET_KEY"
    },
    {
      "type": "random",
      "label": "Utils Secret",
      "min": 64,
      "max": 64,
      "env_variable": "UTILS_SECRET"
    },
    {
      "type": "password",
      "label": "OIDC Client ID",
      "required": true,
      "env_variable": "OIDC_CLIENT_ID"
    },
    {
      "type": "password",
      "label": "OIDC Client Secret",
      "required": true,
      "env_variable": "OIDC_CLIENT_SECRET"
    },
    {
      "type": "text",
      "label": "OIDC Authorize URL (example: https://outline.example.com/application/o/authorize/)",
      "required": true,
      "env_variable": "OIDC_AUTH_URI"
    },
    {
      "type": "text",
      "label": "OIDC Token URL (example: https://outline.example.com/application/o/token/)",
      "required": true,
      "env_variable": "OIDC_TOKEN_URI"
    },
    {
      "type": "text",
      "label": "OIDC Userinfo URL (example: https://outline.example.com/application/o/userinfo/)",
      "required": true,
      "env_variable": "OIDC_USERINFO_URI"
    },
    {
      "type": "text",
      "label": "OIDC Logout URL (example: https://outline.example.com/application/o/end-session/)",
      "required": true,
      "env_variable": "OIDC_LOGOUT_URI"
    },
    {
      "type": "text",
      "label": "OIDC Username Claim (default: preferred_username)",
      "required": true,
      "env_variable": "OIDC_USERNAME_CLAIM"
    },
    {
      "type": "text",
      "label": "OIDC Display Name (default: OpenID Connect)",
      "required": true,
      "env_variable": "OIDC_DISPLAY_NAME"
    },
    {
      "type": "text",
      "label": "OIDC Scopes (default: openid profile email)",
      "required": true,
      "env_variable": "OIDC_SCOPES"
    }
  ],
  "supported_architectures": [
    "arm64",
    "amd64"
  ]
}